{
  "name": "markdown-it-pretext-compatible",
  "version": "0.2.0",
  "description": "A fully compatible markdown-it implementation with a Pretext-inspired prepare() cache.",
  "type": "module",
  "main": "./index.mjs",
  "exports": {
    ".": "./index.mjs",
    "./*": "./*"
  },
  "files": [
    "index.mjs",
    "lib",
    "LICENSE",
    "README.md",
    "demo"
  ],
  "scripts": {
    "test": "mocha test/markdown-it.mjs test/commonmark.mjs test/misc.mjs test/ruler.mjs test/token.mjs test/prepare.mjs test/demo-i18n.mjs",
    "test:stress": "mocha test/pathological.mjs",
    "build:demo": "node scripts/build-demo.mjs"
  },
  "keywords": [
    "markdown",
    "markdown-it",
    "commonmark",
    "parser",
    "pretext"
  ],
  "license": "MIT",
  "dependencies": {
    "entities": "^4.5.0",
    "linkify-it": "^5.0.0",
    "mdurl": "^2.0.0",
    "punycode.js": "^2.3.1"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "esbuild": "^0.25.10",
    "jest-worker": "^29.7.0",
    "markdown-it-for-inline": "^2.0.1",
    "markdown-it-testgen": "^0.1.3",
    "mocha": "^10.8.2",
    "needle": "^3.3.1"
  }
}
